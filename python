    print("Running idkbro Demo...\n")
    
    platform = SocialMediaPlatform(data_dir="demo_data")
    
    # Clear previous demo data
    import shutil
    if os.path.exists("demo_data"):
        shutil.rmtree("demo_data")
    platform = SocialMediaPlatform(data_dir="demo_data")
    
    # Create users
    print("Creating users...")
    platform.register("alice", "Alice Smith", "password123", "Tech enthusiast")
    platform.register("bob", "Bob Jones", "password123", "Coffee lover")
    platform.register("charlie", "Charlie Brown", "password123", "Developer")
    
    # Login as Alice
    platform.login("alice", "password123")
    
    # Post some tweets
    print("\n--- Alice posts tweets ---")
    platform.post_tweet("Just joined this new platform! #excited")
    platform.post_tweet("Working on a cool Python project today 🐍")
    
    # Login as Bob
    platform.logout()
    platform.login("bob", "password123")
    
    # Bob posts and follows Alice
    print("\n--- Bob posts and follows Alice ---")
    platform.post_tweet("Morning coffee is the best! ☕")
    platform.follow_user("alice")
    
    # Login as Charlie
    platform.logout()
    platform.login("charlie", "password123")
    
